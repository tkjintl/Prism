# ── Aurum Prism · Environment Variables ──────────────────────
# Copy this to .env.local for local dev, or set in Vercel Dashboard

# REQUIRED — generate: openssl rand -base64 32
PRISM_SECRET=your-secret-here

# REQUIRED — format: email:password,email2:password2
ADMIN_USERS=ops@theaurumcc.com:YourStrongPassword!

# REQUIRED — get from resend.com (verify prism@theaurumcc.com domain)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxx

# REQUIRED — your deployment URL (no trailing slash)
SITE_URL=https://prism.theaurumcc.com

# REQUIRED — Upstash Redis (create at upstash.com)
KV_REST_API_URL=https://your-instance.upstash.io
KV_REST_API_TOKEN=your-upstash-token

# Operator notification emails (comma-separated)
NOTIFY_EMAILS=ops@theaurumcc.com

# OPTIONAL — TACC bridge secret for deal feed endpoint
# PRISM_TACC_BRIDGE_SECRET=your-bridge-secret
